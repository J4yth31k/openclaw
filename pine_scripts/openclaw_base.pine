//@version=5
indicator("OpenClaw Base Signal", overlay=true, max_bars_back=500)

// ─── Inputs ───────────────────────────────────────────────────────────────────
fast_len   = input.int(9,    "Fast EMA",      minval=1)
slow_len   = input.int(21,   "Slow EMA",      minval=1)
rsi_len    = input.int(14,   "RSI Length",    minval=1)
vol_mult   = input.float(1.2,"Volume Filter", minval=0.5, step=0.1)
tier       = input.string("premium", "Tier",  options=["premium","free"])
filter_session = input.bool(true, "Session Filter (RTH only)")

// ─── Core indicators ──────────────────────────────────────────────────────────
fast_ema   = ta.ema(close, fast_len)
slow_ema   = ta.ema(close, slow_len)
rsi_val    = ta.rsi(close, rsi_len)
atr_val    = ta.atr(14)
vol_ratio  = volume / ta.sma(volume, 20)

// ─── Session filter ───────────────────────────────────────────────────────────
// RTH = 9:30–16:00 ET  |  set to "0000-0000" to disable
in_session = not na(time("1", "0930-1600", "America/New_York"))
session_ok = filter_session ? in_session : true

// ─── Signals ──────────────────────────────────────────────────────────────────
bull = ta.crossover(fast_ema, slow_ema)  and rsi_val < 70 and vol_ratio >= vol_mult and session_ok
bear = ta.crossunder(fast_ema, slow_ema) and rsi_val > 30 and vol_ratio >= vol_mult and session_ok

// ─── Plots ────────────────────────────────────────────────────────────────────
plot(fast_ema, "Fast EMA", color.new(color.aqua,  20), 1)
plot(slow_ema, "Slow EMA", color.new(color.orange, 20), 1)
plotshape(bull, "BUY",  shape.triangleup,   location.belowbar, color.lime, size=size.small)
plotshape(bear, "SELL", shape.triangledown, location.abovebar, color.red,  size=size.small)

// ─── Alert message builder ────────────────────────────────────────────────────
// Produces the JSON payload sent to your webhook endpoint.
msg(action) =>
    '{"symbol":"'     + syminfo.ticker          + '",'  +
    '"timeframe":"'   + timeframe.period         + '",'  +
    '"action":"'      + action                   + '",'  +
    '"price":'        + str.tostring(close)       + ','  +
    '"rsi":'          + str.tostring(math.round(rsi_val,  2)) + ',' +
    '"atr":'          + str.tostring(math.round(atr_val,  2)) + ',' +
    '"vol_ratio":'    + str.tostring(math.round(vol_ratio,2)) + ',' +
    '"fast_ema":'     + str.tostring(math.round(fast_ema, 2)) + ',' +
    '"slow_ema":'     + str.tostring(math.round(slow_ema, 2)) + ',' +
    '"strategy":"EMA_Cross",'                                       +
    '"tier":"'        + tier                     + '",'  +
    '"source":"tradingview"}'

// ─── Alert conditions ─────────────────────────────────────────────────────────
// In TradingView: Alerts → Create → "OpenClaw BUY" → Webhook URL
alertcondition(bull, "OpenClaw BUY",  msg("BUY"))
alertcondition(bear, "OpenClaw SELL", msg("SELL"))
