# ─── Server ──────────────────────────────────────────────────────────────────
HTTP_PORT=3001
CORS_ORIGINS=http://localhost:8080,https://openclaw.vercel.app

# ─── Provider selection ───────────────────────────────────────────────────────
# Options: rithmic | mock
# Use "mock" for local dev/testing without Rithmic credentials.
MARKET_PROVIDER=mock

# ─── Rithmic credentials ─────────────────────────────────────────────────────
# Your Rithmic login — provided by your prop firm or FCM (futures clearing merchant).
RITHMIC_USERNAME=
RITHMIC_PASSWORD=

# App identity — shown in the Rithmic dashboard; use your app name.
RITHMIC_APP_NAME=OpenClaw
RITHMIC_APP_VERSION=1.0.0

# ─── Rithmic environment ─────────────────────────────────────────────────────
# RITHMIC_ENVIRONMENT selects a preset gateway, infraType, and system name.
# Allowed values:
#   paper     — Rithmic Paper Trading (wss://rituz00100.rithmic.com:443/)
#   rithmic01 — Rithmic 01 live infrastructure
#   rithmic04 — Rithmic 04 live infrastructure
#
# Leave blank and set the individual vars below for custom / prop-firm gateways.
RITHMIC_ENVIRONMENT=paper

# ─── Prop-firm overrides ─────────────────────────────────────────────────────
# These override the environment preset above — set only what differs.
#
# RITHMIC_SYSTEM_NAME: the system name assigned by your prop firm.
#   Examples: "Apex Trader Funding", "Topstep", "MyFundedFutures"
#   Leave blank to use the preset default for RITHMIC_ENVIRONMENT.
RITHMIC_SYSTEM_NAME=

# RITHMIC_GATEWAY_URI: override the gateway WebSocket URL if your firm uses
#   a non-standard gateway. Leave blank to use the preset.
RITHMIC_GATEWAY_URI=

# RITHMIC_INFRA_TYPE: 3 = paper/sim, 1 = live.
#   Leave blank to use the preset (3 for paper, 1 for rithmic01/04).
RITHMIC_INFRA_TYPE=

# ─── SSL / custom certificates ────────────────────────────────────────────────
# If your broker's gateway uses a self-signed CA, set this to the path of
# the CA certificate PEM file. The connection still validates with TLS —
# the cert is loaded as a trusted CA rather than disabling verification.
# Leave blank to use the system root CAs (correct for standard Rithmic gateways).
RITHMIC_CERT_PATH=

# ─── Reconnect settings ───────────────────────────────────────────────────────
# How long to wait before reconnecting after a dropped Rithmic connection (ms).
RITHMIC_RECONNECT_MS=5000

# ─── Data settings ───────────────────────────────────────────────────────────
# How many 1-minute bars to seed on startup per symbol
HISTORY_BARS=300

# Roll period: days before expiry to switch to next front-month contract
CME_ROLL_DAYS=7

# ─── TradingView UDF datafeed ─────────────────────────────────────────────────
# Served at /udf/* — compatible with the TradingView Charting Library datafeed
# spec. No extra config needed; the adapter reads from the active provider.
