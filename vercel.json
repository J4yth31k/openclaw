{
  "version": 2,
  "outputDirectory": ".",
  "routes": [
    { "src": "/simworld/assets/(.*)", "dest": "/public/simworld/assets/$1" },
    { "src": "/simworld",             "dest": "/public/simworld/index.html" },
    { "src": "/simworld/(.*)",        "dest": "/public/simworld/index.html" },
    { "src": "/",                     "dest": "/avengers_rimworld.html" },
    { "src": "/mobile",               "dest": "/mobile.html" },
    { "src": "/(.*\\.html)$",         "dest": "/$1" }
  ]
}
