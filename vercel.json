{
  "version": 2,
  "buildCommand": "cd simworld && npm ci && npm run build && mkdir -p ../public/simworld && cp -r dist/* ../public/simworld/",
  "outputDirectory": ".",
  "installCommand": "",
  "routes": [
    { "src": "/simworld/assets/(.*)", "dest": "/public/simworld/assets/$1" },
    { "src": "/simworld",             "dest": "/public/simworld/index.html" },
    { "src": "/simworld/(.*)",        "dest": "/public/simworld/index.html" },
    { "src": "/avengers_rimworld.html", "dest": "/simworld", "status": 301 },
    { "src": "/",                     "dest": "/openclaw_command.html" },
    { "src": "/hq",                   "dest": "/avengers_hq_unified.html" },
    { "src": "/mobile",               "dest": "/mobile.html" },
    { "src": "/(.*\\.html)$",         "dest": "/$1" }
  ]
}
